{
  "trace": {
    "name": "scenario1_happy_path_resolve_read_comment",
    "description": "Sponsor pastes a SharePoint URL. Agent resolves, reads, and adds a clarifying comment.",
    "user_prompt": "https://tenant.sharepoint.com/sites/eng/Spec.docx — what's 'agentic' here? add a comment asking",
    "expected_tools": [
      "resolve_file_url",
      "read_file",
      "add_file_comment"
    ],
    "tool_args": {
      "resolve_file_url": {"url": "https://tenant.sharepoint.com/sites/eng/Spec.docx"},
      "read_file": {"name": "Spec.docx"},
      "add_file_comment": {"content": "What does 'agentic' mean in this section?"}
    },
    "expected_output_subset": {
      "comment_id": "comment-abc",
      "content": "What does 'agentic' mean in this section?"
    }
  },
  "responses": {
    "routes": [
      {
        "method": "GET",
        "kwargs": {"url__regex": ".*/shares/.*/driveItem"},
        "response": {
          "status": 200,
          "json": {
            "id": "01ITEM",
            "name": "Spec.docx",
            "size": 8192,
            "webUrl": "https://tenant.sharepoint.com/sites/eng/Spec.docx",
            "file": {"mimeType": "application/vnd.openxmlformats-officedocument.wordprocessingml.document"},
            "parentReference": {
              "driveId": "b!eng-drive",
              "siteId": "tenant.sharepoint.com,eng-site,eng-web",
              "driveType": "documentLibrary"
            }
          }
        }
      },
      {
        "method": "GET",
        "kwargs": {"url__regex": ".*/drives/b!eng-drive/items/01ITEM/content\\?format=pdf"},
        "response": {
          "status": 200,
          "content": "%PDF-1.4 stub"
        }
      },
      {
        "method": "POST",
        "kwargs": {"url__regex": ".*/beta/drives/b!eng-drive/items/01ITEM/comments"},
        "response": {
          "status": 201,
          "json": {
            "id": "comment-abc",
            "content": {"contentType": "text", "content": "What does 'agentic' mean in this section?"}
          }
        }
      }
    ]
  }
}
